<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Form Result</title>
    <link rel="stylesheet" href="/css/theme.css">
    <style>
        body { padding: 0; overflow: hidden; }

        .corner {
            position: fixed; width: 22px; height: 22px; z-index: 20;
        }
        .corner::before, .corner::after {
            content: ''; position: absolute; background: rgba(255,255,255,0.45);
        }
        .corner::before { width: 1px; height: 100%; left: 50%; transform: translateX(-50%); }
        .corner::after  { height: 1px; width: 100%; top: 50%;  transform: translateY(-50%); }
        .corner-tl { top: 1.6rem; left: 1.6rem; }
        .corner-tr { top: 1.6rem; right: 1.6rem; }
        .corner-bl { bottom: 1.6rem; left: 1.6rem; }
        .corner-br { bottom: 1.6rem; right: 1.6rem; }

        .label-bar {
            position: fixed; left: 0; right: 0;
            display: flex; align-items: center; z-index: 20; padding: 0 2.8rem;
        }
        .label-bar-top    { top: 1.68rem; }
        .label-bar-bottom { bottom: 1.68rem; }
        .label-bar .line  { flex: 1; height: 1px; background: rgba(255,255,255,0.22); }
        .label-bar span {
            padding: 0 1rem; font-size: 0.7rem; letter-spacing: 0.14em;
            color: rgba(255,255,255,0.38); white-space: nowrap; font-family: var(--font-sans);
        }

        .page-content {
            position: fixed; inset: 0;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 1.6rem; z-index: 10; padding: 5rem;
        }

        .applicant-name {
            font-size: 0.72rem; letter-spacing: 0.2em;
            color: rgba(255,255,255,0.3); font-family: 'Courier New', monospace;
            text-align: center; text-transform: uppercase;
        }

        .page-title {
            font-size: clamp(1.4rem, 3vw, 2.2rem);
            font-weight: 900; color: #fff;
            letter-spacing: -0.02em; margin: 0; text-align: center;
        }

        .analysis-panel {
            display: flex; flex-direction: column;
            gap: 1.6rem; width: 100%; max-width: 480px;
        }

        .rating-block {
            display: flex; flex-direction: column;
            gap: 0.5rem; align-items: center;
        }
        .rating-label {
            font-size: 0.68rem; letter-spacing: 0.16em;
            color: rgba(255,255,255,0.35); font-family: 'Courier New', monospace;
        }
        .rating-display {
            display: flex; align-items: baseline; gap: 0.3rem;
        }
        .rating-number {
            font-size: clamp(4.5rem, 11vw, 7.5rem);
            font-weight: 900; line-height: 1;
            color: var(--primary-color);
            text-shadow: 0 0 50px rgba(200,0,0,0.7);
            font-family: 'Courier New', monospace;
        }
        .rating-denom {
            font-size: 1.8rem; color: rgba(255,255,255,0.2);
            font-family: 'Courier New', monospace;
        }
        .rating-na {
            font-size: 2.5rem; font-weight: 700;
            color: rgba(255,255,255,0.25); font-family: 'Courier New', monospace;
        }

        .score-bar-track {
            height: 3px; background: rgba(255,255,255,0.08);
            border-radius: 2px; overflow: hidden; width: 260px;
        }
        .score-bar-fill {
            height: 100%; background: var(--primary-color);
            box-shadow: 0 0 10px rgba(200,0,0,0.7); border-radius: 2px;
            transition: width 1.6s cubic-bezier(0.25, 1, 0.5, 1); width: 0;
        }

        .divider { height: 1px; background: rgba(255,255,255,0.1); }

        .comment-block { text-align: center; }
        .comment-label {
            font-size: 0.68rem; letter-spacing: 0.16em;
            color: rgba(255,255,255,0.35); font-family: 'Courier New', monospace;
            margin-bottom: 0.5rem;
        }
        .comment-text {
            font-size: 0.95rem; color: rgba(255,255,255,0.65);
            line-height: 1.7; margin: 0; font-style: italic;
        }

        .btn-row { display: flex; gap: 1rem; justify-content: center; }
        .btn-primary-action {
            font-family: var(--font-sans); font-size: 0.88rem;
            font-weight: 700; letter-spacing: 0.06em; color: #fff;
            background: var(--primary-color); border: none; border-radius: 3px;
            padding: 0.7rem 2rem; cursor: pointer;
            transition: background 0.2s ease, transform 0.1s ease;
        }
        .btn-primary-action:hover  { background: var(--primary-hover); }
        .btn-primary-action:active { transform: scale(0.97); }
        .btn-back {
            font-family: var(--font-sans); font-size: 0.82rem;
            font-weight: 500; letter-spacing: 0.06em;
            color: rgba(255,255,255,0.4); background: transparent;
            border: 1px solid rgba(255,255,255,0.15); border-radius: 3px;
            padding: 0.7rem 1.6rem; cursor: pointer;
            transition: color 0.2s, border-color 0.2s, transform 0.1s;
        }
        .btn-back:hover  { color: rgba(255,255,255,0.75); border-color: rgba(255,255,255,0.35); }
        .btn-back:active { transform: scale(0.97); }

        .ui-layer { transition: opacity 0.6s ease; }
        .ui-layer.hidden { opacity: 0; pointer-events: none; }
    </style>
</head>
<body>

    <%- include('partials/ai-head') %>

    <div class="corner corner-tl ui-layer"></div>
    <div class="corner corner-tr ui-layer"></div>
    <div class="corner corner-bl ui-layer"></div>
    <div class="corner corner-br ui-layer"></div>

    <div class="label-bar label-bar-top ui-layer">
        <div class="line"></div>
        <span>HM_2.Semester_I+D &mdash; LANGUAGE EVALUATION</span>
        <div class="line"></div>
    </div>

    <div class="page-content ui-layer">
        <div class="applicant-name">APPLICANT — <%= name %></div>
        <h1 class="page-title">AI EVALUATION</h1>

        <div class="analysis-panel">
            <div class="rating-block">
                <div class="rating-label">LANGUAGE SCORE</div>
                <div class="rating-display">
                    <% if (score !== null && score !== undefined) { %>
                        <span class="rating-number"><%= score %></span>
                        <span class="rating-denom">/ 100</span>
                    <% } else { %>
                        <span class="rating-na">N / A</span>
                    <% } %>
                </div>
                <% if (score !== null && score !== undefined) { %>
                    <div class="score-bar-track">
                        <div class="score-bar-fill" id="scoreBar"></div>
                    </div>
                <% } %>
            </div>

            <div class="divider"></div>

            <div class="comment-block">
                <div class="comment-label">AI ASSESSMENT</div>
                <p class="comment-text">"<%= comment %>"</p>
            </div>

            <div class="btn-row">
                <button class="btn-primary-action" id="leaderboardBtn">View Rankings</button>
                <button class="btn-back" id="retakeBtn">Retake</button>
            </div>
        </div>
    </div>

    <div class="label-bar label-bar-bottom ui-layer">
        <div class="line"></div>
        <span>ANA &mdash; VINCENT &mdash; ANGELINA &mdash; AMELIE &mdash; KONST</span>
        <div class="line"></div>
    </div>

    <script>
        <% if (score !== null && score !== undefined) { %>
        setTimeout(() => {
            document.getElementById('scoreBar').style.width = '<%= score %>%';
        }, 400);
        <% } %>

        function fadeAndNavigate(href) {
            document.querySelectorAll('.ui-layer').forEach(el => el.classList.add('hidden'));
            window.aiHead.wanderTo(0, 0);
            setTimeout(() => {
                window.aiHead.setMode('forward');
                window.aiHead.navigateTo(href);
            }, 1000);
        }

        document.getElementById('leaderboardBtn').addEventListener('click', () => {
            fadeAndNavigate('/leaderboard');
        });
        document.getElementById('retakeBtn').addEventListener('click', () => {
            fadeAndNavigate('/upload');
        });

        // Enqueue the print job before clearing the session result — the two
        // requests race otherwise and /print/enqueue can find nothing to send.
        fetch('/print/enqueue', { method: 'POST' })
            .finally(() => fetch('/upload/clear', { method: 'POST' }));

        // Wander left/right like the index page
        let currentSide = null;
        function pickPosition() {
            currentSide = (currentSide === 'left') ? 'right'
                        : (currentSide === 'right') ? 'left'
                        : (Math.random() < 0.5 ? 'left' : 'right');
            const x = (currentSide === 'left' ? -1 : 1) * (5.0 + Math.random() * 0.8);
            const y = (Math.random() - 0.5) * 2.4;
            return [x, y];
        }

        window.aiHead.setOffset(...pickPosition());
        window.aiHead.setMode('default');

        function scheduleWander() {
            setTimeout(() => {
                window.aiHead.wanderTo(...pickPosition());
                scheduleWander();
            }, 4000 + Math.random() * 3000);
        }
        scheduleWander();
    </script>

    <%- include('partials/page-timeout') %>

</body>
</html>
