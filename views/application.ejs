<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Application</title>
    <link rel="stylesheet" href="/css/theme.css">
    <style>
        body { padding: 0; overflow: hidden; }

        /* Corner crosshair marks */
        .corner {
            position: fixed;
            width: 22px;
            height: 22px;
            z-index: 20;
        }
        .corner::before, .corner::after {
            content: '';
            position: absolute;
            background: rgba(255, 255, 255, 0.45);
        }
        .corner::before { width: 1px; height: 100%; left: 50%; transform: translateX(-50%); }
        .corner::after  { height: 1px; width: 100%; top: 50%;  transform: translateY(-50%); }
        .corner-tl { top: 1.6rem; left: 1.6rem; }
        .corner-tr { top: 1.6rem; right: 1.6rem; }
        .corner-bl { bottom: 1.6rem; left: 1.6rem; }
        .corner-br { bottom: 1.6rem; right: 1.6rem; }

        /* Top / bottom label bars */
        .label-bar {
            position: fixed;
            left: 0; right: 0;
            display: flex;
            align-items: center;
            z-index: 20;
            padding: 0 2.8rem;
        }
        .label-bar-top    { top: 1.68rem; }
        .label-bar-bottom { bottom: 1.68rem; }
        .label-bar .line {
            flex: 1;
            height: 1px;
            background: rgba(255, 255, 255, 0.22);
        }
        .label-bar span {
            padding: 0 1rem;
            font-size: 0.7rem;
            letter-spacing: 0.14em;
            color: rgba(255, 255, 255, 0.38);
            white-space: nowrap;
            font-family: var(--font-sans);
        }

        /* Main centred content */
        .page-content {
            position: fixed;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
            text-align: center;
        }

        .page-title {
            font-size: clamp(3rem, 10vw, 7.5rem);
            font-weight: 900;
            color: #ffffff;
            letter-spacing: -0.02em;
            line-height: 1;
            margin: 0 0 1rem;
        }

        .page-subtitle {
            font-size: 0.92rem;
            color: rgba(255, 255, 255, 0.38);
            margin: 0 0 1.4rem;
            letter-spacing: 0.06em;
        }

        /* Countdown */
        .countdown {
            font-family: 'Courier New', Courier, monospace;
            font-size: clamp(3.5rem, 8vw, 6rem);
            font-weight: 700;
            letter-spacing: 0.06em;
            color: var(--primary-color);
            text-shadow: 0 0 24px rgba(200, 0, 0, 0.5);
            margin: 0 0 1.8rem;
            transition: color 0.5s ease, text-shadow 0.5s ease;
        }
        .countdown.urgent {
            color: #ff2222;
            text-shadow: 0 0 32px rgba(255, 0, 0, 0.8);
            animation: countdown-pulse 0.6s ease-in-out infinite alternate;
        }
        @keyframes countdown-pulse {
            from { opacity: 1; }
            to   { opacity: 0.55; }
        }

        .btn-row {
            display: flex;
            gap: 1rem;
            align-items: center;
        }

        .btn-primary-action {
            font-family: var(--font-sans);
            font-size: 0.88rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            color: #fff;
            background: var(--primary-color);
            border: none;
            border-radius: 3px;
            padding: 0.7rem 2rem;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.1s ease;
        }
        .btn-primary-action:hover  { background: var(--primary-hover); }
        .btn-primary-action:active { transform: scale(0.97); }

        .btn-back {
            font-family: var(--font-sans);
            font-size: 0.82rem;
            font-weight: 500;
            letter-spacing: 0.06em;
            color: rgba(255, 255, 255, 0.4);
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 3px;
            padding: 0.7rem 1.6rem;
            cursor: pointer;
            transition: color 0.2s ease, border-color 0.2s ease, transform 0.1s ease;
        }
        .btn-back:hover  { color: rgba(255,255,255,0.75); border-color: rgba(255,255,255,0.35); }
        .btn-back:active { transform: scale(0.97); }

        /* Fade out all UI layers on action */
        .ui-layer { transition: opacity 0.6s ease; }
        .ui-layer.hidden { opacity: 0; pointer-events: none; }
    </style>
</head>
<body>

    <%- include('partials/ai-head') %>

    <div class="corner corner-tl ui-layer"></div>
    <div class="corner corner-tr ui-layer"></div>
    <div class="corner corner-bl ui-layer"></div>
    <div class="corner corner-br ui-layer"></div>

    <div class="label-bar label-bar-top ui-layer">
        <div class="line"></div>
        <span>HM_2.Semester_I+D &mdash; APPLICATION</span>
        <div class="line"></div>
    </div>

    <div class="page-content ui-layer">
        <h1 class="page-title">FILL OUT<br>THE FORM.</h1>
        <p class="page-subtitle">Complete the form and press finished when done.</p>
        <div class="countdown" id="countdown">5:00</div>
        <div class="btn-row">
            <button class="btn-primary-action" id="finishedBtn">Form Finished</button>
            <button class="btn-back" id="backBtn">Go Back</button>
        </div>
    </div>

    <div class="label-bar label-bar-bottom ui-layer">
        <div class="line"></div>
        <span>ANA &mdash; VINCENT &mdash; ANGELINA &mdash; AMELIE &mdash; KONST</span>
        <div class="line"></div>
    </div>

    <script>
        // ── Countdown timer ───────────────────────────────────────────────────────
        const TOTAL_SECONDS = 5 * 60;
        let secondsLeft = TOTAL_SECONDS;
        let timerDone = false;
        const countdownEl = document.getElementById('countdown');

        function updateCountdown() {
            const m = Math.floor(secondsLeft / 60);
            const s = secondsLeft % 60;
            countdownEl.textContent = `${m}:${String(s).padStart(2, '0')}`;
            if (secondsLeft <= 60) countdownEl.classList.add('urgent');
            if (secondsLeft <= 0) {
                timerDone = true;
                fadeAndNavigate('/');
                return;
            }
            secondsLeft--;
            setTimeout(updateCountdown, 1000);
        }
        updateCountdown();

        function fadeAndNavigate(href) {
            document.querySelectorAll('.ui-layer').forEach(el => el.classList.add('hidden'));
            window.aiHead.wanderTo(0, 0);
            setTimeout(() => {
                window.aiHead.setMode('forward');
                window.aiHead.navigateTo(href);
            }, 1000);
        }

        document.getElementById('finishedBtn').addEventListener('click', () => {
            fadeAndNavigate('/upload');
        });

        document.getElementById('backBtn').addEventListener('click', () => {
            fadeAndNavigate('/');
        });

        // Wander left / right like the index page
        let currentSide = null;
        function pickPosition() {
            currentSide = (currentSide === 'left') ? 'right'
                        : (currentSide === 'right') ? 'left'
                        : (Math.random() < 0.5 ? 'left' : 'right');
            const x = (currentSide === 'left' ? -1 : 1) * (5.0 + Math.random() * 0.8);
            const y = (Math.random() - 0.5) * 2.4;
            return [x, y];
        }

        window.aiHead.setOffset(...pickPosition());

        function scheduleWander() {
            setTimeout(() => {
                window.aiHead.wanderTo(...pickPosition());
                scheduleWander();
            }, 4000 + Math.random() * 3000);
        }
        scheduleWander();
    </script>

    <%- include('partials/page-timeout') %>

</body>
</html>
