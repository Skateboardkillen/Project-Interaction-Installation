<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Apply Now</title>
    <link rel="stylesheet" href="/css/theme.css">
    <style>
        body { padding: 0; overflow: hidden; }

        /* Corner crosshair marks */
        .corner {
            position: fixed;
            width: 22px;
            height: 22px;
            z-index: 20;
        }
        .corner::before, .corner::after {
            content: '';
            position: absolute;
            background: rgba(255, 255, 255, 0.45);
        }
        .corner::before { width: 1px; height: 100%; left: 50%; transform: translateX(-50%); }
        .corner::after  { height: 1px; width: 100%; top: 50%;  transform: translateY(-50%); }
        .corner-tl { top: 1.6rem; left: 1.6rem; }
        .corner-tr { top: 1.6rem; right: 1.6rem; }
        .corner-bl { bottom: 1.6rem; left: 1.6rem; }
        .corner-br { bottom: 1.6rem; right: 1.6rem; }

        /* Top / bottom label bars */
        .label-bar {
            position: fixed;
            left: 0; right: 0;
            display: flex;
            align-items: center;
            z-index: 20;
            padding: 0 2.8rem;
        }
        .label-bar-top    { top: 1.68rem; }
        .label-bar-bottom { bottom: 1.68rem; }
        .label-bar .line {
            flex: 1;
            height: 1px;
            background: rgba(255, 255, 255, 0.22);
        }
        .label-bar span {
            padding: 0 1rem;
            font-size: 0.7rem;
            letter-spacing: 0.14em;
            color: rgba(255, 255, 255, 0.38);
            white-space: nowrap;
            font-family: var(--font-sans);
        }

        /* Main centred content */
        .index-content {
            position: fixed;
            inset: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 10;
            gap: 0;
            text-align: center;
        }

        .index-title {
            font-size: clamp(4rem, 13vw, 9.5rem);
            font-weight: 900;
            color: #ffffff;
            letter-spacing: -0.02em;
            line-height: 1;
            margin: 0 0 1rem;
        }

        .index-subtitle {
            font-size: 0.92rem;
            color: rgba(255, 255, 255, 0.45);
            max-width: 340px;
            line-height: 1.65;
            margin: 0 0 1.6rem;
        }

        .btn-apply {
            font-family: var(--font-sans);
            font-size: 0.88rem;
            font-weight: 700;
            letter-spacing: 0.06em;
            color: #fff;
            background: var(--primary-color);
            border: none;
            border-radius: 3px;
            padding: 0.7rem 2rem;
            cursor: pointer;
            transition: background 0.2s ease, transform 0.1s ease;
        }
        .btn-apply:hover  { background: var(--primary-hover); }
        .btn-apply:active { transform: scale(0.97); }

        .btn-leaderboard {
            position: fixed;
            bottom: 2.8rem;
            right: 3.2rem;
            font-family: var(--font-sans);
            font-size: 0.75rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            color: rgba(255, 255, 255, 0.3);
            background: transparent;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 3px;
            padding: 0.5rem 1.2rem;
            cursor: pointer;
            z-index: 30;
            transition: color 0.2s, border-color 0.2s, transform 0.1s;
        }
        .btn-leaderboard:hover  { color: rgba(255,255,255,0.65); border-color: rgba(255,255,255,0.28); }
        .btn-leaderboard:active { transform: scale(0.97); }

        /* Fade out all UI overlay elements on start */
        .ui-layer {
            transition: opacity 0.6s ease;
        }
        .ui-layer.hidden {
            opacity: 0;
            pointer-events: none;
        }
    </style>
</head>
<body>

    <%- include('partials/ai-head') %>

    <div class="corner corner-tl ui-layer"></div>
    <div class="corner corner-tr ui-layer"></div>
    <div class="corner corner-bl ui-layer"></div>
    <div class="corner corner-br ui-layer"></div>

    <div class="label-bar label-bar-top ui-layer">
        <div class="line"></div>
        <span>HM_2.Semester_I+D</span>
        <div class="line"></div>
    </div>

    <div class="index-content ui-layer">
        <h1 class="index-title">APPLY NOW!</h1>
        <p class="index-subtitle">Reflect on your language privilege through an application process. Pick a form and press start.</p>
        <button class="btn-apply" id="startBtn">Start</button>
    </div>

    <div class="label-bar label-bar-bottom ui-layer">
        <div class="line"></div>
        <span>ANA &mdash; VINCENT &mdash; ANGELINA &mdash; AMELIE &mdash; KONST</span>
        <div class="line"></div>
    </div>

    <button class="btn-leaderboard ui-layer" id="leaderboardBtn">VIEW RANKINGS</button>

    <script>
        document.getElementById('startBtn').addEventListener('click', () => {
            document.querySelectorAll('.ui-layer').forEach(el => el.classList.add('hidden'));
            window.aiHead.wanderTo(0, 0);
            setTimeout(() => {
                window.aiHead.setMode('forward');
                window.aiHead.navigateTo('/installation-explanation');
            }, 1000);
        });

        document.getElementById('leaderboardBtn').addEventListener('click', () => {
            document.querySelectorAll('.ui-layer').forEach(el => el.classList.add('hidden'));
            window.aiHead.wanderTo(0, 0);
            setTimeout(() => {
                window.aiHead.setMode('displaying');
                window.aiHead.navigateTo('/leaderboard');
            }, 800);
        });

        // Alternates strictly left / right; Y is randomised each time
        let currentSide = null;
        function pickPosition() {
            currentSide = (currentSide === 'left') ? 'right'
                        : (currentSide === 'right') ? 'left'
                        : (Math.random() < 0.5 ? 'left' : 'right'); // first call: random
            const x = (currentSide === 'left' ? -1 : 1) * (5.0 + Math.random() * 0.8);
            const y = (Math.random() - 0.5) * 2.4;
            return [x, y];
        }

        // Snap to a random starting spot, then wander on a randomised timer
        window.aiHead.setOffset(...pickPosition());

        function scheduleWander() {
            setTimeout(() => {
                window.aiHead.wanderTo(...pickPosition());
                scheduleWander();
            }, 4000 + Math.random() * 3000);
        }
        scheduleWander();
    </script>

</body>
</html>
