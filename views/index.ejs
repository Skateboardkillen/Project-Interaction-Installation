<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Themeable App</title>
    <link rel="stylesheet" href="/css/theme.css">
</head>
<body>

    <%- include('partials/ai-head') %>

    <div class="screen-bottom">
        <button class="btn-start" id="startBtn">Start Installation</button>
    </div>

    <script>
        document.getElementById('startBtn').addEventListener('click', () => {
            window.aiHead.setMode('forward');
            window.aiHead.navigateTo('/installation-explanation');
        });
    </script>

</body>
</html>
